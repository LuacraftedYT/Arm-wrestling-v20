local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "LUACRAFTED V86 | PLATFORM FARM",
   LoadingTitle = "DEPLOYING INVISIBLE PLATFORM...",
   LoadingSubtitle = "Network Sync + Blacklist System",
   ConfigurationSaving = { Enabled = false },
   KeySystem = false 
})

local FarmTab = Window:CreateTab("🪓 Chaos Island", 4483362458) 

--- [[ 1. SERVICES & KNIT SETUP ]] ---
local Player = game.Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")

task.wait(1)
local Knit = require(ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Knit"))
local ChaosService = Knit.GetService("ChaosBreakablesService")

--- [[ 2. VARIABLES & SIGNALS ]] ---
local selectedTree = "All Options"
local autoFarmActive = false
local lastDamageTime = os.clock()
local buggedTrees = {} -- The Blacklist array

local damageSignal = ChaosService.DamageBreakableSignal
if damageSignal then
    damageSignal:Connect(function()
        lastDamageTime = os.clock() 
    end)
end

--- [[ 3. THE INVISIBLE PLATFORM FIX ]] ---
-- Spawn an invisible floor for the player to stand on so we don't need to use Anchor
local platform = workspace:FindFirstChild("LuacraftedPlatform")
if not platform then
    platform = Instance.new("Part")
    platform.Name = "LuacraftedPlatform"
    platform.Size = Vector3.new(5, 1, 5)
    platform.Anchored = true
    platform.Transparency = 1
    platform.CanCollide = true
    platform.Parent = workspace
end

local function preciseGlide(targetPos)
    local char = Player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    
    if root then
        -- Never anchor the player again!
        root.Anchored = false 
        
        local flatRoot = Vector3.new(root.Position.X, targetPos.Y, root.Position.Z)
        local direction = (flatRoot - targetPos).Unit
        
        if direction.Magnitude ~= direction.Magnitude then 
            direction = Vector3.new(1, 0, 0) 
        end
        
        -- Move 2 studs away, 3.5 studs high
        local safePos = targetPos + (direction * 2) + Vector3.new(0, 3.5, 0)
        
        -- Teleport the invisible platform directly under the player's feet
        platform.Position = safePos - Vector3.new(0, 3, 0)
        
        -- Teleport the player ONTO the platform
        root.CFrame = CFrame.lookAt(safePos, Vector3.new(targetPos.X, safePos.Y, targetPos.Z))
        
        -- Give the server a split second to register you landing on the platform
        task.wait(0.1) 
    end
end

--- [[ 4. UI COMPONENTS ]] ---
FarmTab:CreateDropdown({
   Name = "Select Tree Target",
   Options = {"All Options", "PalmTree", "ChaosTree"},
   CurrentOption = {"All Options"},
   Callback = function(Option) 
       selectedTree = Option[1] 
   end,
})

FarmTab:CreateToggle({
   Name = "Start Blacklist Auto-Break",
   CurrentValue = false,
   Callback = function(Value)
       autoFarmActive = Value
       local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
       
       if not Value then 
           if root then root.Anchored = false end
           platform.Position = Vector3.new(0, -10000, 0) -- Hide platform when off
       end
       
       if autoFarmActive then
           table.clear(buggedTrees) -- Clear the blacklist when you start fresh
           lastDamageTime = os.clock()
           
           task.spawn(function()
               while autoFarmActive do
                   local breakables = workspace.GameObjects.ChaosBreakables:GetDescendants()
                   
                   for _, tree in ipairs(breakables) do
                       if not autoFarmActive then break end
                       
                       -- Verify tree is alive AND not in our Blacklist
                       if tree:IsA("Model") and tree:GetAttribute("Destroyed") ~= true and not buggedTrees[tree] then
                           local isMatch = false
                           if selectedTree == "All Options" then isMatch = true 
                           elseif string.find(tree.Name, selectedTree) then isMatch = true end
                           
                           local hitPart = tree:FindFirstChild("XZBounds") or tree.PrimaryPart
                           
                           if isMatch and hitPart then
                               preciseGlide(hitPart.Position)
                               lastDamageTime = os.clock() 
                               
                               while autoFarmActive and tree:GetAttribute("Destroyed") ~= true do
                                   pcall(function() 
                                       ChaosService:Clicked() 
                                   end)
                                   
                                   -- ⚡ THE BLACKLIST FAILSAFE ⚡
                                   if os.clock() - lastDamageTime > 3 then
                                       print("⚠️ Failsafe: Tree is bugged or desynced. Adding to Blacklist!")
                                       buggedTrees[tree] = true -- Throw it in the trash
                                       break -- Skip to the next tree instantly
                                   end
                                   
                                   task.wait(0.05) 
                               end
                           end
                       end
                   end
                   task.wait(0.5)
               end
           end)
       end
   end,
})

FarmTab:CreateLabel("Uses an invisible platform to guarantee server sync.")
