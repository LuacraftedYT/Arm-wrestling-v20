local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "LUACRAFTED V78 | SKYHOPPER",
   LoadingTitle = "BYPASSING TERRAIN...",
   LoadingSubtitle = "Native Hitboxes + Hop Tweens",
   ConfigurationSaving = { Enabled = false }
})

local FarmTab = Window:CreateTab("🪓 Chaos Island", 4483362458) 

--- [[ 1. SERVICES & KNIT SETUP ]] ---
local Player = game.Players.LocalPlayer
local TweenService = game:GetService("TweenService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Wait for the game to load controllers
task.wait(1)
local Knit = require(ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Knit"))
local ChaosService = Knit.GetService("ChaosBreakablesService")

--- [[ 2. VARIABLES ]] ---
local selectedTree = "All Options"
local autoFarmActive = false

--- [[ 3. THE "HOP TWEEN" MOVEMENT LOGIC ]] ---
local function preciseGlide(targetPos)
    local char = Player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    
    if root then
        root.Anchored = false 
        
        -- Flatten the direction math so we don't calculate weird vertical angles
        local flatRoot = Vector3.new(root.Position.X, targetPos.Y, root.Position.Z)
        local direction = (flatRoot - targetPos).Unit
        
        -- Fallback if you are perfectly inside the tree's center
        if direction.Magnitude ~= direction.Magnitude then 
            direction = Vector3.new(1, 0, 0) 
        end
        
        -- The Final Hitting Spot (3 studs away, 4.5 studs high to prevent floor clipping)
        local safePos = targetPos + (direction * 3) + Vector3.new(0, 4.5, 0)
        
        -- The "Sky" Spot (15 studs higher to clear all rocks and hills)
        local skyPos = Vector3.new(safePos.X, safePos.Y + 15, safePos.Z)
        
        -- TWEEN 1: Fly up and over the rocks
        local tweenOver = TweenService:Create(root, TweenInfo.new(0.3, Enum.EasingStyle.Sine), {
            CFrame = CFrame.lookAt(skyPos, Vector3.new(targetPos.X, skyPos.Y, targetPos.Z))
        })
        tweenOver:Play()
        tweenOver.Completed:Wait() 
        
        -- TWEEN 2: Drop straight down into the exact hitting position
        local tweenDown = TweenService:Create(root, TweenInfo.new(0.15, Enum.EasingStyle.Sine), {
            CFrame = CFrame.lookAt(safePos, Vector3.new(targetPos.X, safePos.Y, targetPos.Z))
        })
        tweenDown:Play()
        tweenDown.Completed:Wait() 
        
        -- Lock in place for the server-validated hits
        root.Anchored = true
    end
end

--- [[ 4. UI COMPONENTS ]] ---
FarmTab:CreateDropdown({
   Name = "Select Tree Target",
   Options = {"All Options", "PalmTree", "ChaosTree"},
   CurrentOption = {"All Options"},
   Callback = function(Option) 
       selectedTree = Option[1] 
   end,
})

FarmTab:CreateToggle({
   Name = "Start Skyhopper Auto-Break",
   CurrentValue = false,
   Callback = function(Value)
       autoFarmActive = Value
       local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
       
       -- Unanchor if turned off
       if not Value and root then root.Anchored = false end
       
       if autoFarmActive then
           task.spawn(function()
               while autoFarmActive do
                   -- Locate the Breakables Folder natively
                   local breakables = workspace.GameObjects.ChaosBreakables:GetDescendants()
                   
                   for _, tree in ipairs(breakables) do
                       if not autoFarmActive then break end
                       
                       -- Verify tree is alive using the game's internal attribute
                       if tree:IsA("Model") and tree:GetAttribute("Destroyed") ~= true then
                           
                           -- Match the tree type
                           local isMatch = false
                           if selectedTree == "All Options" then isMatch = true 
                           elseif string.find(tree.Name, selectedTree) then isMatch = true end
                           
                           local hitPart = tree:FindFirstChild("XZBounds") or tree.PrimaryPart
                           
                           if isMatch and hitPart then
                               -- Execute the Hop Tween to get into position
                               preciseGlide(hitPart.Position)
                               
                               -- Spam the Native Clicked remote until the game marks it as Destroyed
                               while autoFarmActive and tree:GetAttribute("Destroyed") ~= true do
                                   pcall(function() 
                                       ChaosService:Clicked() 
                                   end)
                                   task.wait(0.05) -- Lightning speed
                               end
                               
                               -- Unanchor to prepare for the next hop
                               root = Player.Character:FindFirstChild("HumanoidRootPart")
                               if root then root.Anchored = false end
                           end
                       end
                   end
                   -- Brief pause before scanning for newly spawned trees
                   task.wait(0.5)
               end
           end)
       end
   end,
})

FarmTab:CreateLabel("100% Native Hook. Clears terrain obstacles automatically.")
