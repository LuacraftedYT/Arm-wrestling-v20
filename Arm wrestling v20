--- Smart Math Database ---
local axes = {
    {name = "Wooden", cd = 0.75, dmg = 2},
    {name = "Stone", cd = 0.70, dmg = 4},
    {name = "Iron", cd = 0.60, dmg = 6},
    {name = "Gold", cd = 0.50, dmg = 10},
    {name = "Diamond", cd = 0.35, dmg = 18}
}

local currentAxeIndex = 1
local currentTargetHP = 50 

local function getHitsNeeded()
    return math.ceil(currentTargetHP / axes[currentAxeIndex].dmg)
end

--- Services ---
local KnitServices = game:GetService("ReplicatedStorage"):WaitForChild("Packages"):WaitForChild("Knit"):WaitForChild("Services")
