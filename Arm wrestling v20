    if currentAxeIndex > #axes then currentAxeIndex = 1 end
    AxeCycleButton.Text = "Axe: " .. axes[currentAxeIndex].name .. " (" .. axes[currentAxeIndex].cd .. "s)"
    AxeCycleButton.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
    task.wait(0.2)
    AxeCycleButton.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
end)

--- 1. LEGIT AUTO CLICK ---
AutoClickButton.MouseButton1Click:Connect(function()
    clicking = not clicking
    AutoClickButton.Text = clicking and "Auto Click: ON" or "Auto Click: OFF"
    AutoClickButton.BackgroundColor3 = clicking and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(50, 50, 50)

    task.spawn(function()
        local clickRemote = ChaosService:WaitForChild("Clicked")
        while clicking do
            task.spawn(function() clickRemote:InvokeServer() end)
            -- Waits the EXACT amount of time the server requires
