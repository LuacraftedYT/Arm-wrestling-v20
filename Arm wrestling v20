--- 3. LEGIT AUTO FARM ---
local function glideTo(targetPos)
    local char = Player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root then
        local targetCFrame = CFrame.new(targetPos.X, root.Position.Y, targetPos.Z) * CFrame.new(0, 0, 3)
        local tween = TweenService:Create(root, TweenInfo.new(0.3, Enum.EasingStyle.Sine), {CFrame = targetCFrame})
        tween:Play()
        tween.Completed:Wait()
    end
end

AutoFarmButton.MouseButton1Click:Connect(function()
    farming = not farming
    AutoFarmButton.Text = farming and "Auto Farm: ON" or "Auto Farm: OFF"
    AutoFarmButton.BackgroundColor3 = farming and Color3.fromRGB(0, 180, 80) or Color3.fromRGB(50, 50, 50)

    task.spawn(function()
        while farming do
            local children = AxeFolder:GetChildren()
            local clickRemote = ChaosService:WaitForChild("Clicked")
            
            for i = 1, 15 do
                if not farming then break end
                local tree = children[i]
                
                if tree and tree.Parent then
                    local hitPart = tree:IsA("BasePart") and tree or tree:FindFirstChildWhichIsA("BasePart")
                    if hitPart then
                        glideTo(hitPart.Position)
                        local hitsRequired = getHitsNeeded()
                        
                        for hit = 1, hitsRequired do
                            if not farming then break end
                            task.spawn(function() clickRemote:InvokeServer() end)
                            task.wait(axes[currentAxeIndex].cd) 
                        end
                    end
                end
            end
            task.wait(0.5)
        end
    end)
end)
