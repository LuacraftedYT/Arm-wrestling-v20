})

--- [[ 2. AUTO-EGG ]] ---
local eggDict = {
    ["Earth Egg"] = "Unknown", 
    ["Alien Egg"] = "Unknown", 
    ["Chaotic Egg"] = "Unknown", 
    ["Radioactive Egg"] = "Unknown"
}

pcall(function()
    for _, zone in ipairs(workspace.Zones:GetChildren()) do
        local interactables = zone:FindFirstChild("Interactables")
        if interactables and interactables:FindFirstChild("Eggs") then
            for _, obj in ipairs(interactables.Eggs:GetDescendants()) do
                if obj:IsA("ProximityPrompt") then
                    local attr = obj:GetAttribute("Egg")
                    if attr then
                        local lowerAttr = string.lower(attr)
                        if string.find(lowerAttr, "earth") then eggDict["Earth Egg"] = attr end
                        if string.find(lowerAttr, "alien") or string.find(lowerAttr, "crushcore") then eggDict["Alien Egg"] = attr end
                        if string.find(lowerAttr, "chaos") then eggDict["Chaotic Egg"] = attr end
                        if string.find(lowerAttr, "atomic") or string.find(lowerAttr, "radioactive") then eggDict["Radioactive Egg"] = attr end
                    end
                end
            end
        end
    end
end)

local exactEggString = eggDict["Earth Egg"]

EggTab:CreateDropdown({
    Name = "Select Egg to Hatch",
    Options = {"Earth Egg", "Alien Egg", "Chaotic Egg", "Radioactive Egg"},
    CurrentOption = {"Earth Egg"},
    MultipleOptions = false,
    Callback = function(Option) exactEggString = eggDict[Option[1]] end
})

EggTab:CreateToggle({
   Name = "Start Native Auto-Hatch",
   CurrentValue = false,
   Callback = function(Value)
       _G.AutoEgg = Value
       if Value and EggController then
           task.spawn(function()
               while _G.AutoEgg do
                   if exactEggString ~= "Unknown" then
                       pcall(function() 
                           local triple = Player:GetAttribute("TripleEggs") or false
                           local octo = Player:GetAttribute("OctoEggs") or false
                           EggController:openEgg(triple, exactEggString, octo, true) 
                       end)
                   end
                   task.wait(0.1)
               end
           end)
       end
   end,
})

