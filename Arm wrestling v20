local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "LUACRAFTED HUB | Arm Wrestle Simulator",
   LoadingTitle = "LUACRAFTED V25",
   LoadingSubtitle = "Injecting Modules...",
   ConfigurationSaving = { Enabled = false },
   KeySystem = false 
})

local FarmTab = Window:CreateTab("Chaos Island", 4483362458) 

local Player = game.Players.LocalPlayer
local TweenService = game:GetService("TweenService")
local KnitServices = game:GetService("ReplicatedStorage"):WaitForChild("Packages"):WaitForChild("Knit"):WaitForChild("Services")
local ChaosService = KnitServices:WaitForChild("ChaosBreakablesService"):WaitForChild("RF")
local AxeFolder = workspace:WaitForChild("GameObjects"):WaitForChild("ChaosBreakables"):WaitForChild("Axe")

local selectedTree = "All Options"
local selectedAxeCD = 0.75 
local autoFarmActive = false

local function glideTo(targetPos)
    local char = Player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root then
        local targetCFrame = CFrame.new(targetPos.X, root.Position.Y, targetPos.Z) * CFrame.new(0, 0, 3)
        local tween = TweenService:Create(root, TweenInfo.new(0.3, Enum.EasingStyle.Sine), {CFrame = targetCFrame})
        tween:Play()
        tween.Completed:Wait()
    end
end

FarmTab:CreateDropdown({
   Name = "Select Tree Target",
   Options = {"All Options", "PalmTree", "ChaosTree"},
   CurrentOption = {"All Options"},
   MultipleOptions = false,
   Flag = "TreeSelect",
   Callback = function(Option)
       selectedTree = Option[1]
   end,
})

FarmTab:CreateDropdown({
   Name = "Select Equipped Axe",
   Options = {"Wooden (0.75s)", "Stone (0.70s)", "Iron (0.60s)", "Gold (0.50s)", "Diamond (0.35s)"},
   CurrentOption = {"Wooden (0.75s)"},
   MultipleOptions = false,
   Flag = "AxeSelect",
   Callback = function(Option)
       local choice = Option[1]
       if choice:match("Wooden") then selectedAxeCD = 0.75
       elseif choice:match("Stone") then selectedAxeCD = 0.70
       elseif choice:match("Iron") then selectedAxeCD = 0.60
       elseif choice:match("Gold") then selectedAxeCD = 0.50
       elseif choice:match("Diamond") then selectedAxeCD = 0.35
       end
   end,
})

FarmTab:CreateToggle({
   Name = "Auto Break Tree",
   CurrentValue = false,
   Flag = "AutoFarm",
   Callback = function(Value)
       autoFarmActive = Value
       
       if autoFarmActive then
           task.spawn(function()
               local clickRemote = ChaosService:WaitForChild("Clicked")
               
               while autoFarmActive do
                   for _, tree in ipairs(AxeFolder:GetChildren()) do
                       if not autoFarmActive then break end
                       
                       local treeName = tree.Name
                       local isMatch = false
                       
                       if selectedTree == "All Options" then
                           isMatch = true
                       elseif selectedTree == "PalmTree" and string.find(string.lower(treeName), "palm") then
                           isMatch = true
                       elseif selectedTree == "ChaosTree" and string.find(string.lower(treeName), "chaos") then
                           isMatch = true
                       end
                       
                       if isMatch and tree:FindFirstChildWhichIsA("BasePart") then
                           local hitPart = tree:FindFirstChildWhichIsA("BasePart")
                           glideTo(hitPart.Position)
                           
                           while tree and tree.Parent and tree:FindFirstChildWhichIsA("BasePart") and autoFarmActive do
                               task.spawn(function() clickRemote:InvokeServer() end)
                               task.wait(selectedAxeCD) 
                           end
                       end
                   end
                   task.wait(0.5) 
               end
           end)
       end
   end,
})
