local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "LUACRAFTED V77 | PRECISE FARM",
   LoadingTitle = "CALIBRATING HITBOXES...",
   LoadingSubtitle = "3-Stud Precision Mode",
   ConfigurationSaving = { Enabled = false }
})

local FarmTab = Window:CreateTab("🪓 Chaos Island", 4483362458) 

--- Services & Knit Setup ---
local Player = game.Players.LocalPlayer
local TweenService = game:GetService("TweenService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Knit = require(ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Knit"))

-- Native Controller & Services
local ChaosService = Knit.GetService("ChaosBreakablesService")

--- Variables ---
local selectedTree = "All Options"
local autoFarmActive = false

--- [[ THE 3-STUD PRECISION TWEEN ]] ---
local function preciseGlide(targetPos)
    local char = Player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root then
        root.Anchored = false 
        
        -- 1. Calculate a position exactly 3 studs away from the tree
        -- We add 4.5 to the Y-axis to prevent your feet from clipping into the floor
        local direction = (root.Position - targetPos).Unit
        local safePos = targetPos + (direction * 3) + Vector3.new(0, 4.5, 0)
        
        -- 2. Create a CFrame that faces the tree exactly (using the game's native logic)
        local targetCFrame = CFrame.lookAt(safePos, Vector3.new(targetPos.X, safePos.Y, targetPos.Z))
        
        -- 3. Smoothly move to the position
        local tween = TweenService:Create(root, TweenInfo.new(0.4, Enum.EasingStyle.Sine), {CFrame = targetCFrame})
        tween:Play()
        tween.Completed:Wait()
        
        -- 4. Lock in place for the hits
        root.Anchored = true
    end
end

--- UI Components ---
FarmTab:CreateDropdown({
   Name = "Select Tree Target",
   Options = {"All Options", "PalmTree", "ChaosTree"},
   CurrentOption = {"All Options"},
   Callback = function(Option) selectedTree = Option[1] end,
})

FarmTab:CreateToggle({
   Name = "Native Auto-Break (3-Stud Mode)",
   CurrentValue = false,
   Callback = function(Value)
       autoFarmActive = Value
       local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
       
       if not Value and root then root.Anchored = false end
       
       if autoFarmActive then
           task.spawn(function()
               while autoFarmActive do
                   -- Locate the Breakables Folder
                   local breakables = workspace.GameObjects.ChaosBreakables:GetDescendants()
                   
                   for _, tree in ipairs(breakables) do
                       if not autoFarmActive then break end
                       
                       -- Verify tree is alive using the game's internal attribute
                       if tree:IsA("Model") and tree:GetAttribute("Destroyed") ~= true then
                           
                           local isMatch = false
                           if selectedTree == "All Options" then isMatch = true 
                           elseif string.find(tree.Name, selectedTree) then isMatch = true end
                           
                           local hitPart = tree:FindFirstChild("XZBounds") or tree.PrimaryPart
                           
                           if isMatch and hitPart then
                               -- Move to the 3-stud offset
                               preciseGlide(hitPart.Position)
                               
                               -- Spam the Clicked remote natively
                               while autoFarmActive and tree:GetAttribute("Destroyed") ~= true do
                                   pcall(function() 
                                       ChaosService:Clicked() 
                                   end)
                                   task.wait(0.05) 
                               end
                               
                               if root then root.Anchored = false end
                           end
                       end
                   end
                   task.wait(0.5)
               end
           end)
       end
   end,
})
